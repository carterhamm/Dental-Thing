# === Backend (Python / Railway) ===

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Firebase service account (download from Firebase Console → Project Settings → Service Accounts)
GOOGLE_APPLICATION_CREDENTIALS=serviceAccountKey.json

# Twilio (get from twilio.com/console)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ElevenLabs Conversational AI (get from elevenlabs.io dashboard)
ELEVENLABS_API_KEY=...
ELEVENLABS_AGENT_ID=...
ELEVENLABS_PHONE_NUMBER_ID=...

# Public URL of this server (set after deploying to Railway)
# Twilio webhooks and ElevenLabs webhooks point here
SERVER_URL=https://your-app.up.railway.app

# === Frontend (Vite / Vercel) ===

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ElevenLabs TTS (for dashboard narration — optional)
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_VOICE_ID=
